# User configuration
export SAVEHIST=9223372036854775807
export HISTSIZE=9223372036854775807
export KEYTIMEOUT=15

{{ if .machine.macos -}}
export LANG="en_US.UTF-8"
{{ else -}}
export LANG="en_IN.UTF-8"
{{ end -}}
export TZ="Asia/Kolkata"

export EDITOR="nvim"
export VISUAL="$EDITOR"

# pnpm
export PNPM_HOME="$HOME/.local/share/pnpm"
# pnpm end

export path=(
  "$HOME/.krew/bin"
  "$PNPM_HOME"
  "$HOME/.local/bin"

  {{ if .machine.macos -}}
  {{   if .machine.work -}}
  "$HOME/Library/Application Support/Coursier/bin"
  {{   end -}}
  "/opt/homebrew/opt/helm@3/bin"
  "/opt/homebrew/bin"
  "/opt/homebrew/opt/curl/bin"
  "/opt/homebrew/opt/llvm/bin"
  "/opt/homebrew/opt/mysql-client/bin"
  "/opt/homebrew/sbin"
  {{ else -}}
  "/home/linuxbrew/.linuxbrew/bin"
  "/home/linuxbrew/.linuxbrew/sbin"
  {{ end -}}

  $path
)
export fpath=("$HOME/.zfunc" "$(brew --prefix)/share/zsh/site-functions" $fpath)

{{ if .machine.macos -}}
# Compilation flags
export LDFLAGS="-L/opt/homebrew/opt/curl/lib"
export CPPFLAGS="-I/opt/homebrew/opt/curl/include"

# pkg-config
export PKG_CONFIG_PATH="/opt/homebrew/opt/curl/lib/pkgconfig"
{{- end }}
# End User configuration

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME=""
HYPHEN_INSENSITIVE="true"
zstyle ':omz:update' mode disabled
DISABLE_UNTRACKED_FILES_DIRTY="true"

plugins=(
  # Needs to be at the top
  mise

  docker
  docker-compose
  gcloud
  git
  jj
  kubectl
  pre-commit
  starship
  sudo
  zoxide
  zsh-autosuggestions
  zsh-syntax-highlighting

  {{ if .machine.macos -}}
  gnu-utils
  macos
  {{ else -}}
  systemd
  ubuntu
  {{- end }}
)
zstyle ':completion:*:*:docker:*' option-stacking yes
zstyle ':completion:*:*:docker-*:*' option-stacking yes

# Path to the completion cache file
ZSH_COMPDUMP="${ZSH_CACHE_DIR:-$HOME/.cache}/.zcompdump-${ZSH_VERSION}"

export ZSH_DISABLE_COMPFIX=true
source "$ZSH/oh-my-zsh.sh"

source "$HOME/.local/share/aliases.zsh"
source "$HOME/.local/share/exports.zsh"
source "$HOME/.local/share/functions.zsh"

[ x"$(command -v atuin)" != x"" ] && eval "$(atuin init zsh --disable-up-arrow)"
