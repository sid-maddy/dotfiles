{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  "disabled_hooks": ["session-notification"],

  // ─── Agent Model Assignments ───────────────────────────────
  "agents": {
    "sisyphus": {
      "model": "google-vertex-anthropic/claude-opus-4-6@default",
      "variant": "max"
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
          "variant": "medium"
        }
      ]
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        {
          "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
          "variant": "high"
        }
      ]
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini-fast",
      "fallback_models": [
        { "model": "openai/gpt-5.4-nano" }
      ]
    },
    "explore": {
      "model": "openai/gpt-5.4-mini-fast",
      "fallback_models": [
        { "model": "openai/gpt-5.4-nano" }
      ]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        { "model": "openai/gpt-5-nano" }
      ]
    },
    "prometheus": {
      "model": "google-vertex-anthropic/claude-opus-4-6@default",
      "variant": "max",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "high"
        },
        { "model": "google-vertex-anthropic/claude-sonnet-4-6@default" }
      ]
    },
    "metis": {
      "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
      "fallback_models": [
        {
          "model": "google-vertex-anthropic/claude-opus-4-6@default",
          "variant": "max"
        },
        {
          "model": "openai/gpt-5.5",
          "variant": "high"
        },
      ]
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
          "variant": "medium"
        }
      ]
    },
    "atlas": {
      "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
      "variant": "medium",
      "fallback_models": [
        { "model": "openai/gpt-5.4-mini" }
      ]
    },
    "sisyphus-junior": {
      "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        },
      ]
    }
  },

  // ─── Task Category Models ──────────────────────────────────
  "categories": {
    "visual-engineering": {
      "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        }
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
          "variant": "medium"
        }
      ]
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
          "variant": "medium"
        }
      ]
    },
    "artistry": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        {
          "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
          "variant": "medium"
        }
      ]
    },
    "quick": {
      "model": "openai/gpt-5.4-mini"
    },
    "unspecified-low": {
      "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
      "variant": "medium",
      "fallback_models": [
        { "model": "openai/gpt-5.4-mini" }
      ]
    },
    "unspecified-high": {
      "model": "google-vertex-anthropic/claude-opus-4-6@default",
      "variant": "max",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "high"
        },
        {
          "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
          "variant": "medium"
        }
      ]
    },
    "writing": {
      "model": "google-vertex-anthropic/claude-sonnet-4-6@default",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        }
      ]
    }
  },

  // ─── Fallback & Resilience ─────────────────────────────────
  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [400, 429, 503, 529],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 45,
    "notify_on_fallback": true
  },

  // ─── Edit Engine ───────────────────────────────────────────
  "hashline_edit": true,

  // ─── Background Tasks ──────────────────────────────────────
  "background_task": {
    "providerConcurrency": {
      "google-vertex-anthropic": 10,
      "openai": 10,
    },
    "modelConcurrency": {
      "google-vertex-anthropic/claude-opus-4-6@default": 10,
      "google-vertex-anthropic/claude-sonnet-4-6@default": 10,
      "openai/gpt-5.5": 6,
      "openai/gpt-5.4-mini": 10,
      "openai/gpt-5.4-mini-fast": 10,
      "openai/gpt-5.4-nano": 10,
      "openai/gpt-5-nano": 10,
    },
    "maxDepth": 5,
    "maxDescendants": 20,
    "circuitBreaker": {
      "enabled": true,
      "maxToolCalls": 500,
      "consecutiveThreshold": 20
    }
  },

  // ─── Experimental ──────────────────────────────────────────
  "experimental": {
    "auto_resume": true,
    "task_system": true,
    "model_fallback_title": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "detailed",
      "turn_protection": {
        "enabled": true,
        "turns": 5
      },
      "protected_tools": [
        "task",
        "todowrite",
        "todoread",
        "lsp_rename",
        "session_read",
        "session_write",
        "session_search"
      ],
      "strategies": {
        "deduplication": { "enabled": true },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        }
      }
    }
  },

  // ─── Misc ──────────────────────────────────────────────────
  "babysitting": {
    "timeout_ms": 120000
  },
  "start_work": {
    "auto_commit": true
  },
  "model_capabilities": {
    "enabled": true,
    "refresh_timeout_ms": 5000
  },
  "tmux": {
    "enabled": true
  },
  "team_mode": {
    "enabled": true,
    "tmux_visualization": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "max_messages_per_run": 10000,
    "max_wall_clock_minutes": 120,
    "max_member_turns": 500,
    "message_payload_max_bytes": 32768,
    "recipient_unread_max_bytes": 262144,
    "mailbox_poll_interval_ms": 3000
  },
  "git_master": {
    "include_co_authored_by": true
  }
}
