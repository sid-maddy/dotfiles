[settings]
auto_install                        = false
exec_auto_install                   = false
experimental                        = true
idiomatic_version_file_enable_tools = ['rust']
not_found_auto_install              = false
task_run_auto_install               = false
trusted_config_paths                = ['~/.config/mise']

  [settings.npm]
  bun = true

  [settings.pipx]
  uvx = true

  # [settings.python]
  # uv_venv_auto = true

[tools]
bun     = 'latest'
deno    = 'latest'
elixir  = 'latest'
erlang  = 'latest'
go      = 'latest'
kubectl = ['latest', '1.33', '1.31']
node    = 'lts'
python  = ['latest', 'sub-0.1:latest', 'sub-0.2:latest', 'sub-0.3:latest', 'sub-0.4:latest']
ruby    = 'latest'
rust    = 'latest'
stylua  = 'latest'
uv      = 'latest'
{{- if .machine.work }}
java    = 'graalvm-community-25'
scala   = 'latest'
{{- end }}

# Erlang
rebar = 'latest'

# Go
'go:github.com/ankitpokhrel/jira-cli/cmd/jira'              = 'latest'
'go:github.com/charmbracelet/glow'                          = 'latest'
'go:github.com/go-delve/delve/cmd/dlv'                      = 'latest'
'go:github.com/golangci/golangci-lint/v2/cmd/golangci-lint' = 'latest'
'go:github.com/goreleaser/goreleaser'                       = 'latest'
'go:github.com/grafana/dashboard-linter'                    = 'latest'
'go:github.com/grafana/grafanactl/cmd/grafanactl'           = 'latest'
'go:github.com/nats-io/natscli/nats'                        = 'latest'
'go:github.com/oligot/go-mod-upgrade'                       = 'latest'
'go:github.com/spf13/cobra-cli'                             = 'latest'
'go:github.com/zmwangx/ets'                                 = 'latest'
'go:go.k6.io/xk6/cmd/xk6'                                   = 'latest'
'go:sigs.k8s.io/kubectl-validate'                           = 'latest'

# Node.js
'npm:@google/gemini-cli' = 'latest'
'npm:@openai/codex'      = 'latest'
'npm:renovate'           = 'latest'

# Python
'pipx:code-review-graph' = {version = 'latest', extras = 'all'}
'pipx:iredis'            = 'latest'
'pipx:marimo'            = {version = 'latest', extras = 'recommended,lsp'}
'pipx:memray'            = 'latest'
'pipx:mycli'             = 'latest'
'pipx:pdm'               = 'latest'
'pipx:pgcli'             = {version = 'latest', uvx_args = '--with psycopg[binary]'}
'pipx:pip-tools'         = 'latest'
'pipx:poetry'            = {version = 'latest', uvx_args = '--with poetry-plugin-export'}
'pipx:prek'              = 'latest'
'pipx:pyupgrade'         = 'latest'
'pipx:virtualenv'        = 'latest'

# Rust
'cargo:cargo-edit'     = 'latest'
'cargo:cargo-generate' = 'latest'
'cargo:cargo-outdated' = 'latest'
'cargo:cargo-valgrind' = 'latest'

'cargo:atuin'    = 'latest'
'cargo:yazi-cli' = 'latest'
'cargo:yazi-fm'  = 'latest'

# LSP Servers (opencode/omo)
'go:golang.org/x/tools/gopls'           = 'latest'
'npm:bash-language-server'              = 'latest'
'npm:dockerfile-language-server-nodejs' = 'latest'
'npm:pyright'                           = 'latest'
'npm:typescript-language-server'        = 'latest'
'npm:vscode-langservers-extracted'      = 'latest'
'npm:yaml-language-server'              = 'latest'
'pipx:ty'                               = 'latest'
